# Copy to web/.env.local and fill in.

# REQUIRED locally for AI Gateway-backed analysis and harness calls.
# The implementation uses AI SDK 6 model IDs directly through AI Gateway.
AI_GATEWAY_API_KEY=

# OPTIONAL, preferred BYOK provider credential for OpenAI-over-Gateway.
# If present, requests still authenticate to AI Gateway first, then Gateway uses this key for OpenAI.
OPENAI_API_KEY=sk-...

# OPTIONAL direct-provider fallback only. The default implementation should route through AI Gateway.
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL model overrides. Defaults: OpenAI BYOK if OPENAI_API_KEY is present,
# otherwise Anthropic via Gateway.
ANALYSIS_MODEL=openai/gpt-5.1-instant
HARNESS_MODEL=openai/gpt-5.4-nano

# REQUIRED for >60 req/hr — server-side authenticated GitHub API.
# A read-only token with no scopes is enough; we only hit public endpoints.
# Without this, demo will rate-limit after a few volunteer handles.
GITHUB_TOKEN=ghp_...

# OPTIONAL public demo guard. Vetted handles bypass cold-analysis quotas.
# Comma-separated list of GitHub handles you control or have consent to feature.
VETTED_HANDLES=
PUBLIC_COLD_ANALYSIS_DAILY_LIMIT=250
PUBLIC_COLD_ANALYSIS_PER_CLIENT_HOURLY_LIMIT=12
PUBLIC_CHAT_PER_CLIENT_HOURLY_LIMIT=30
PUBLIC_LENS_PER_CLIENT_HOURLY_LIMIT=12
PUBLIC_ANALYSIS_GUARD=on

# OPTIONAL — for agent-harness, override the web app target.
BASE_URL=http://localhost:3000
